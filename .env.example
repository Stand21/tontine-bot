# ----- Telegram -----
# 1) Parle à @BotFather sur Telegram → /newbot → récupère le token ci-dessous
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 2) Envoie /start à ton bot, il te renverra ton chat ID. Colle-le ici.
TELEGRAM_CHAT_ID=123456789

# ----- Sécurité -----
# Clé secrète : protège /notify et /set-webhook, et sert de chemin au webhook.
NOTIFY_KEY=change-moi-une-longue-cle-secrete
WEBHOOK_SECRET=autre-chaine-secrete-pour-le-webhook

# ----- Options -----
# RUN_CRON=true seulement si le service ne s'endort pas. En free tier, laisse false + cron externe.
RUN_CRON=false
TZ=Africa/Abidjan
